# ============================================================
# 生产/本机测试环境变量模板
# ------------------------------------------------------------
# 使用方式:
#   cp deployment/.env.prod.example deployment/.env.prod
#   # 然后按下方注释逐项填写；带 [必填] 标记的必须设置
#
# 生成随机密钥（3 个密码位都建议重新生成）:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 注意：.env.prod 不要提交到 git！.dockerignore 已排除。
# ============================================================

# ─────────── 运行参数（本机测试保持默认）───────────
API_WORKERS=2
LOG_LEVEL=info
TASK_TIMEOUT_SECONDS=1800
TASK_MAX_CONCURRENT=2

# ─────────── 密钥（[必填] 全部替换为随机字符串）───────────
JWT_SECRET_KEY=CHANGE_ME_random_32_bytes_urlsafe_token
SECRET_KEY=CHANGE_ME_random_32_bytes_urlsafe_token

# ─────────── PostgreSQL（[必填] 改密码）───────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ─────────── Redis（[必填] 改密码）───────────
REDIS_PASSWORD=CHANGE_ME_strong_password

# ─────────── MinIO（[必填] 用户名+密码，密码≥8位）───────────
# 迁移模式：本机已有 MinIO 数据（RELEASE.2024-08-17 完全兼容），
# 想直接复用不做拷贝，取消下行注释并指向本机 data 目录：
# MINIO_DATA_PATH=D:\DevelopFiles\minio\data
#
# 注意：使用该模式时 MINIO_ROOT_USER/PASSWORD 必须与本机一致（默认 minioadmin/minioadmin），
#       否则新凭证覆盖旧凭证会导致已有 bucket 无法读取。
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=petfood-bucket
# 预签名 URL 的外部端点（浏览器能访问到的地址）
# 本机：http://localhost:9000
# 服务器：http://your-server-ip:9000  或走 /minio-api 代理: http://your-domain/minio-api
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_PUBLIC_URL=http://localhost:9001

# ─────────── CORS / 主机白名单 ───────────
# JSON 数组字符串，本机测试保持默认即可
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:5173","capacitor://localhost","https://localhost"]
ALLOWED_HOSTS=["*"]

# ─────────── 前端构建参数（编译期写入 React）───────────
# 本机通过 Nginx 访问，前端直接走相对路径即可：
VITE_API_BASE_URL=http://localhost/api/v1
VITE_ENABLE_SSE=true
VITE_RECONNECT_DELAY=3000

# ─────────── LLM API（[必填] 至少 DashScope 和 Tavily）───────────
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
TAVILIY_API_KEY=tvly-your-tavily-key

# 可选：备用模型
ZAI_API_KEY=
ZAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
SILICONFLOW_API_BASE=https://api.siliconflow.cn
MOONSHOT_API_KEY=

# ─────────── 邮件（可选，不填则注册验证码走日志）───────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
