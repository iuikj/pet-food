# Docker 构建忽略文件

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 虚拟环境
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 测试
.pytest_cache/
.coverage
htmlcov/
*.cover

# Git
.git/
.gitignore
.gitattributes

# 文档
docs/
*.md
!README.md

# 部署
deployment/nginx/ssl/*.pem
deployment/nginx/ssl/*.key

# 日志
*.log
logs/

# 临时文件
*.tmp
*.bak
.DS_Store

# 环境变量（敏感，由 compose --env-file 注入，不入镜像）
.env
.env.*
!.env.example

# 大数据资源
knowledge/
notebooks/
*.ipynb

# 不需要的缓存
.ruff_cache/
.mypy_cache/
